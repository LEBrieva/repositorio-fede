---
import { getTranslations, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="experience" class="reveal py-20 lg:py-28 bg-background">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-primary mb-4">
        {t.experience.sectionTitle}
      </h2>
      <div class="w-16 h-1 bg-primary-light mx-auto rounded-full"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-stretch">
      <!-- Founder Card -->
      <div class="bg-background-alt rounded-2xl p-8 lg:p-10">
        <div class="flex items-center gap-4 mb-6">
          <img src="/images/socios/fede.png" alt="Federico Cuadra" class="w-16 h-16 rounded-full object-cover flex-shrink-0" />
          <div class="flex-1">
            <h3 class="font-display text-2xl font-bold text-primary">{t.experience.founderName}</h3>
            <p class="text-primary-light font-medium">{t.experience.founderRole}</p>
          </div>
          <a href="https://www.linkedin.com/in/federicocuadra/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-primary hover:bg-primary-light text-white rounded-lg flex items-center justify-center transition-colors flex-shrink-0" aria-label="LinkedIn de Federico Cuadra">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
        <p class="text-text-light text-lg leading-relaxed">
          {t.experience.founderBio}
        </p>
      </div>

      <!-- Origin Card -->
      <div class="bg-gradient-to-br from-primary to-primary-dark rounded-2xl p-8 lg:p-10 text-white">
        <div class="flex items-center gap-3 mb-6">
          <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <h3 class="font-display text-2xl font-bold">{t.experience.originTitle}</h3>
        </div>
        <p class="text-white/80 text-lg leading-relaxed">
          {t.experience.originText}
        </p>
      </div>
    </div>
  </div>
</section>
