---
import { getTranslations, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const avatars = [
  '/images/socios/caro-avatar.png',
  '/images/socios/daniela-avatar.png',
  '/images/socios/matias-avatar.png',
];
---

<section id="allies" class="reveal py-20 lg:py-28 bg-background-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-primary mb-4">
        {t.allies.sectionTitle}
      </h2>
      <div class="w-16 h-1 bg-primary-light mx-auto mb-6 rounded-full"></div>
      <p class="text-text-light text-lg max-w-2xl mx-auto">
        {t.allies.sectionSubtitle}
      </p>
    </div>

    <!-- DM Consultores Logo -->
    <div class="flex justify-center mb-12">
      <div class="bg-background rounded-2xl p-6 shadow-sm">
        <img src="/images/logos/logo-aliados.jpeg" alt="DM Consultores" class="h-16 object-contain" />
      </div>
    </div>

    <!-- Ally Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {t.allies.members.map((member, i) => (
        <div class="bg-background rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-transparent hover:border-primary-light/20 text-center">
          <img src={avatars[i]} alt={member.name} class="w-16 h-16 rounded-full object-cover mx-auto mb-6" />
          <h3 class="font-display text-xl font-semibold text-primary mb-1">
            <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-primary-light transition-colors">
              {member.name}
              <svg class="w-4 h-4 text-primary-light" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </h3>
          <p class="text-primary-light text-sm font-medium mb-3">
            {member.role}
          </p>
          <p class="text-text-light leading-relaxed">
            {member.specialty}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
