---
import { getTranslations, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const phone = '5491144381857';
const waBase = `https://wa.me/${phone}?text=`;

function buildWaUrl(serviceTitle: string) {
  const msg = locale === 'es'
    ? `Hola, me contacto desde la web de BC Consultores. Me interesa el servicio de *${serviceTitle}*. ¿Podrían darme más información?`
    : `Hi, I'm reaching out from the BC Consultores website. I'm interested in the *${serviceTitle}* service. Could you give me more information?`;
  return `${waBase}${encodeURIComponent(msg)}`;
}

const block1Icons = [
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
];

const block2Icons = [
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
];

const block1Items = t.services.items.slice(0, 4);
const block2Items = t.services.items.slice(4, 7);

const waIcon = `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---

<section id="services" class="reveal py-20 lg:py-28 bg-background-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-primary mb-4">
        {t.services.sectionTitle}
      </h2>
      <div class="w-16 h-1 bg-primary-light mx-auto mb-6 rounded-full"></div>
      <p class="text-text-light text-lg max-w-2xl mx-auto">
        {t.services.sectionSubtitle}
      </p>
    </div>

    <!-- Block 1 -->
    <div class="mb-16">
      <h3 class="font-display text-xl sm:text-2xl font-semibold text-primary-light mb-8 text-center">
        {t.services.block1Title}
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {block1Items.map((service, i) => (
          <a
            href={buildWaUrl(service.title)}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-background rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-transparent hover:border-primary-light/20 flex flex-col"
          >
            <div class="w-14 h-14 bg-primary/5 group-hover:bg-primary-light/10 rounded-xl flex items-center justify-center text-primary group-hover:text-primary-light transition-colors duration-300 mb-6">
              <Fragment set:html={block1Icons[i]} />
            </div>
            <h3 class="font-display text-xl font-semibold text-primary mb-3">
              {service.title}
            </h3>
            <p class="text-text-light leading-relaxed flex-1">
              {service.description}
            </p>
            <span class="inline-flex items-center gap-2 text-green-600 text-sm font-medium mt-4 group-hover:gap-3 transition-all">
              <Fragment set:html={waIcon} />
              {t.services.serviceCta}
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Block 2 -->
    <div>
      <h3 class="font-display text-xl sm:text-2xl font-semibold text-primary-light mb-8 text-center">
        {t.services.block2Title}
      </h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {block2Items.map((service, i) => (
          <a
            href={buildWaUrl(service.title)}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-background rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-transparent hover:border-primary-light/20 flex flex-col"
          >
            <div class="w-14 h-14 bg-primary/5 group-hover:bg-primary-light/10 rounded-xl flex items-center justify-center text-primary group-hover:text-primary-light transition-colors duration-300 mb-6">
              <Fragment set:html={block2Icons[i]} />
            </div>
            <h3 class="font-display text-xl font-semibold text-primary mb-3">
              {service.title}
            </h3>
            <p class="text-text-light leading-relaxed flex-1">
              {service.description}
            </p>
            <span class="inline-flex items-center gap-2 text-green-600 text-sm font-medium mt-4 group-hover:gap-3 transition-all">
              <Fragment set:html={waIcon} />
              {t.services.serviceCta}
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
