---
import { getTranslations, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="posts" class="reveal py-20 lg:py-28 bg-background-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-background rounded-2xl shadow-sm border border-primary/10 overflow-hidden">
      <div class="grid lg:grid-cols-2 items-center">
        <!-- Content -->
        <div class="p-10 lg:p-14">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-[#0A66C2] rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-primary">
              {t.posts.sectionTitle}
            </h2>
          </div>
          <p class="text-text-light text-lg leading-relaxed mb-8">
            {t.posts.sectionSubtitle}
          </p>
          <a
            href="https://www.linkedin.com/company/business-case-consultores"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-[#0A66C2] hover:bg-[#004182] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-[#0A66C2]/25"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            {t.posts.followUs}
          </a>
        </div>

        <!-- Visual -->
        <div class="hidden lg:block">
          <img src="images/posts/content-linkedin.png" alt={t.posts.sectionTitle} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </div>
</section>
