---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Experience from '../components/Experience.astro';
import Allies from '../components/Allies.astro';
import Posts from '../components/Posts.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const locale = 'es';
---

<Layout
  title="BC Consultores - Business Case | Asesoramiento Contable y Financiero"
  description="Business Case Consultores. Asesoramiento contable, impositivo y financiero para pymes y emprendimientos en Buenos Aires."
  lang="es"
>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <About locale={locale} />
    <Services locale={locale} />
    <Experience locale={locale} />
    <Allies locale={locale} />
    <Posts locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
