---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import About from '../../components/About.astro';
import Services from '../../components/Services.astro';
import Experience from '../../components/Experience.astro';
import Allies from '../../components/Allies.astro';
import Posts from '../../components/Posts.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';

const locale = 'en';
---

<Layout
  title="BC Consultores - Business Case | Accounting & Financial Advisory"
  description="Business Case Consultores. Accounting, tax, and financial advisory for SMEs and startups in Buenos Aires."
  lang="en"
>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <About locale={locale} />
    <Services locale={locale} />
    <Experience locale={locale} />
    <Allies locale={locale} />
    <Posts locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
